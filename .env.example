# Server
PORT=3000
NODE_ENV=development


# M-PESA CREDENTIALS
# Get from: https://developer.safaricom.co.ke

# For Testing (Sandbox)
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=paste_your_sandbox_consumer_key_here
MPESA_CONSUMER_SECRET=paste_your_sandbox_consumer_secret_here
MPESA_PASSKEY=paste_your_sandbox_passkey_here
MPESA_SHORTCODE=174379

# For Production (Live - after PayBill approval)
# MPESA_ENVIRONMENT=production
# MPESA_CONSUMER_KEY=paste_your_production_consumer_key_here
# MPESA_CONSUMER_SECRET=paste_your_production_consumer_secret_here
# MPESA_PASSKEY=paste_your_production_passkey_here
# MPESA_SHORTCODE=your_paybill_or_till_number

# Callback URL
# Local testing: http://localhost:3000/api/payment/callback
# With ngrok: http://abc123.ngrok.io/api/payment/callback
# Production: https://yourstore.com/api/payment/callback
MPESA_CALLBACK_URL=http://localhost:3000/api/payment/callback

# SECURITY

# Generate random secret:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DOWNLOAD_TOKEN_SECRET=change_this_to_a_random_64_character_string_here

# Download expiry (milliseconds)
# 86400000 = 24 hours
DOWNLOAD_LINK_EXPIRY=86400000
